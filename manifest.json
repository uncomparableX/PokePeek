{
  "manifest_version": 3,
  "name": "Pokemon Screen Pets",
  "version": "1.0",
  "description": "Pikachu, Bulbasaur, Charmander, and Squirtle playing at the bottom of your screen!",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["style.css"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/*.gif"],
      "matches": ["<all_urls>"]
    }
  ]
}